generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  CLINICIAN
  MODERATOR
  ADMIN
}

model User {
  id             String   @id @default(uuid())
  userName       String   @unique
  email          String   @unique
  firstName      String
  lastName       String
  phone          String   @unique
  birthDate      String
  region         String
  passwordHash   String
  passwordSalt   String
  externalUserId String?
  role           Role     @default(PATIENT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authSessions   AuthSession[]
  customerRefs   CustomerReference[]
  rapidStepTests RapidStepTest[]
  escalations    Escalation[]
  pushTokens     PushToken[]
  auditEvents    AuditEvent[]
}

model AuthSession {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomerReference {
  id                 String   @id @default(uuid())
  name               String
  phone              String   @unique
  email              String   @unique
  userId             String?
  externalCustomerId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  voiceSessions VoiceSession[]
}

model Consent {
  id        String   @id @default(uuid())
  customer  String   @unique
  status    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsentedClinician {
  id                String   @id @default(uuid())
  customer          String
  clinicianUsername String
  createdAt         DateTime @default(now())

  @@unique([customer, clinicianUsername])
}

model ClinicianAccessRequest {
  id                String   @id @default(uuid())
  clinicianUsername String
  customerEmail     String
  status            String // pending, approved, denied
  requestDate       DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([customerEmail, clinicianUsername])
}

enum TestSource {
  MOBILE
  IVR
  MOCK
  EXTERNAL
}

model RapidStepTest {
  id             String     @id @default(uuid())
  userId         String
  externalTestId String?
  testData       Json
  source         TestSource
  createdAt      DateTime   @default(now())
  completedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ResponsePreference {
  CALL
  TEXT
  CHAT
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum Category {
  MEDICAL
  TECHNICAL
  GENERAL
}

enum EscalationStatus {
  PENDING
  ASSIGNED
  RESOLVED
}

model Escalation {
  escalationId        String             @id @unique
  userId              String?
  phoneNumber         String
  originalQuestion    String
  aiResponse          String
  questionTimestamp   DateTime
  escalationTimestamp DateTime
  responsePreference  ResponsePreference
  waitingForResponse  Boolean            @default(true)
  priority            Priority
  category            Category
  status              EscalationStatus   @default(PENDING)
  coachId             String?
  resolutionTimestamp DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  coachResponses CoachResponse[]
}

model CoachResponse {
  id             String   @id @default(uuid())
  escalationId   String
  coachId        String
  message        String
  deliveryMethod String
  deliveryStatus String
  createdAt      DateTime @default(now())

  escalation Escalation @relation(fields: [escalationId], references: [escalationId], onDelete: Cascade)
}

model ChatSession {
  id                String   @id // Using chatSessionId as PK
  userId            String?
  threadId          String?
  context           Json
  nextStep          String
  sessionActive     Boolean  @default(true)
  accessibilityMode Boolean?
  locale            String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messages ChatMessage[]

  @@index([threadId])
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatMessage {
  id            String   @id @default(uuid())
  chatSessionId String
  role          ChatRole
  message       String
  metadata      Json?
  createdAt     DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VoiceStage {
  INITIAL
  AWAITING_PHONE
  AWAITING_DOB
  AUTHENTICATING
  AWAITING_TEST_CHOICE
  TEST_IN_PROGRESS
  COMPLETED
  FAILED
}

model VoiceSession {
  id                     String     @id @default(uuid())
  callSid                String     @unique
  stage                  VoiceStage
  phoneNumber            String?
  customerReferenceId    String?
  authenticationAttempts Int        @default(0)
  testStartedAt          DateTime?
  testCompletedAt        DateTime?
  callStatus             String?
  expiresAt              DateTime
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  customerReference CustomerReference? @relation(fields: [customerReferenceId], references: [id], onDelete: SetNull)
}

model VoiceTest {
  id          String    @id @default(uuid())
  callSid     String    @unique
  userId      String?
  email       String?
  status      String
  testData    Json
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model SmsConsentMessage {
  id          String   @id @default(uuid())
  messageSid  String   @unique
  userId      String?
  phoneNumber String
  status      String
  simulated   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model OutboxEvent {
  id          String       @id @default(uuid())
  eventType   String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  maxAttempts Int          @default(3)
  availableAt DateTime
  lockedAt    DateTime?
  processedAt DateTime?
  lastError   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, availableAt])
}

model RagDocument {
  id        String   @id @default(uuid())
  title     String
  source    String
  section   String?
  metadata  Json
  checksum  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks RagChunk[]
}

model RagChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String
  section    String?
  metadata   Json
  // pgvector extension would use Unsupported("vector(1536)") or similar, but for now String or Json if pgvector unsupported in base prisma.
  // We'll use Json for embedding fallback if Unsupported causes issues locally without db push
  embedding  Json?
  createdAt  DateTime @default(now())

  document RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id           String   @id @default(uuid())
  userId       String?
  eventType    String
  entityType   String
  entityId     String
  safeMetadata Json
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
